# Required: MongoDB connection string (no local fallback).
# Use MongoDB Atlas (free tier): https://www.mongodb.com/cloud/atlas
# Copy this file to .env and set your real values.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nest-auth?retryWrites=true&w=majority

# Server
PORT=3000

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=86400

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Optional: OAuth (leave as dummy if not using)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/redirect
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=
